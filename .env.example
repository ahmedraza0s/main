# ==========================================
# LIVEKIT CLOUD CREDENTIALS
# Get these from: https://cloud.livekit.io/
# ==========================================

# Your project URL (starts with wss://)
LIVEKIT_URL=wss://your-project.livekit.cloud

# API Key and Secret from Project Settings > Keys
LIVEKIT_API_KEY=APIabc123...
LIVEKIT_API_SECRET=secret...


# ==========================================
# AI MODEL KEYS
# ==========================================

# OpenAI for LLM (Brain)
OPENAI_API_KEY=sk-...

# Deepgram for STT (Hearing)
DEEPGRAM_API_KEY=...

# Cartesia (optional) or OpenAI for TTS (Speaking)
# TTS Config (openai, cartesia, sarvam)
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
CARTESIA_TTS_MODEL=sonic-2
CARTESIA_TTS_VOICE=f786b574-daa5-4673-aa0c-cbe3e8534c02
SARVAM_API_KEY=
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TARGET_LANGUAGE_CODE=hi-IN


# ==========================================
# VOBIZ SIP TRUNK CONFIGURATION
# Get these from the Vobiz Console Platform: https://console.vobiz.ai/
# ==========================================

# The SIP Domain provided by Vobiz
VOBIZ_SIP_DOMAIN=your_sip_domain.sip.vobiz.ai

# Your SIP Username
VOBIZ_USERNAME=your_username

# Your SIP Password
VOBIZ_PASSWORD=your_password

# Your DID (Phone Number) for outbound calls
# Must include country code (e.g., +91...)
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX

# Default number to transfer call to
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# Webhook configuration
WEBHOOK_URL=https://your-webhook-url.com/webhook/12345
